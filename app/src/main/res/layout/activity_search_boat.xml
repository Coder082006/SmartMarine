<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Top App Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#1A237E"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Smart Marine Booking"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Content Area -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="28dp"
            android:paddingBottom="32dp">

            <!-- Page Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Search Boats"
                android:textColor="#111111"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginBottom="28dp" />

            <!-- FROM Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="From"
                android:textColor="#333333"
                android:textSize="14sp"
                android:layout_marginBottom="8dp" />

            <!-- FROM Spinner -->
            <Spinner
                android:id="@+id/spinnerFrom"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/spinner_border"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginBottom="20dp"
                android:prompt="@string/from_prompt" />

            <!-- TO Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="To"
                android:textColor="#333333"
                android:textSize="14sp"
                android:layout_marginBottom="8dp" />

            <!-- TO Spinner -->
            <Spinner
                android:id="@+id/spinnerTo"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/spinner_border"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginBottom="20dp"
                android:prompt="@string/to_prompt" />

            <!-- TRAVEL DATE Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Travel Date"
                android:textColor="#333333"
                android:textSize="14sp"
                android:layout_marginBottom="8dp" />

            <!-- TRAVEL DATE Picker (styled as dropdown) -->
            <LinearLayout
                android:id="@+id/layoutDatePicker"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/spinner_border"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginBottom="32dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/tvSelectedDate"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Thu. 15 Jun 2024"
                    android:textColor="#222222"
                    android:textSize="15sp" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/arrow_drop_down"
                    android:contentDescription="Pick date" />
            </LinearLayout>

            <!-- SEARCH Button -->
            <Button
                android:id="@+id/btnSearch"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="SEARCH"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:backgroundTint="#1A237E"
                app:cornerRadius="6dp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
